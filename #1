const likedPosts = new Set();

function likePosts() {
  const likeButtons = [...document.querySelectorAll('button[aria-label="Reaction button state: no reaction"]')]
    .filter(btn => !likedPosts.has(btn));

  likeButtons.forEach((btn, i) => {
    likedPosts.add(btn);
    setTimeout(() => {
      btn.click();
      console.log(`Liked post #${likedPosts.size}`);
    }, i * 1200);
  });

  return likeButtons.length;
}

function clickLoadMore() {
  const loadMoreBtn = [...document.querySelectorAll('button')]
    .find(btn => btn.innerText.trim() === 'Load more');

  if (loadMoreBtn) {
    loadMoreBtn.scrollIntoView({ behavior: 'smooth' });
    setTimeout(() => {
      loadMoreBtn.click();
      console.log('Clicked "Load more" to load new posts.');
    }, 1000);
    return true;
  }
  return false;
}

function run() {
  // Step 1: Like all visible unliked posts
  const count = likePosts();
  console.log(`Liking ${count} posts...`);

  // Step 2: Slowly scroll down after liking
  setTimeout(() => {
    window.scrollBy({ top: 600, behavior: 'smooth' });

    // Step 3: Try clicking "Load more" if it's now visible
    setTimeout(() => {
      const clicked = clickLoadMore();
      if (!clicked) {
        // If no "Load more" yet, just keep scrolling
        window.scrollBy({ top: 600, behavior: 'smooth' });
      }
    }, 1500);

  }, count * 1200 + 500);
}

// Run once immediately, then every 5 seconds
run();
let autoLike = setInterval(run, 5000);

